# Bolna
BOLNA_API_KEY=your_bolna_api_key
BOLNA_AGENT_ID=your_agent_id

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/bolna_alerts

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
LOG_LEVEL=INFO

# Optional: restrict webhook to Bolna IP
BOLNA_WEBHOOK_IP=13.203.39.153
ENABLE_IP_WHITELIST=false
